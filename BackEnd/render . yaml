services:
  # خدمة الويب لتطبيق Laravel (الباك إند فقط)
  - type: web
    name: huma-hr-backend
    env: docker
    plan: free
    region: frankfurt # يمكنك تغييرها لـ ohio لتكون أقرب لـ TiDB إذا أردت
    dockerContext: BackEnd
    dockerfilePath: Dockerfile
    envVars:
      - key: APP_ENV
        value: production
      - key: APP_DEBUG
        value: "false"
      - key: DB_CONNECTION
        value: mysql
      - key: DB_HOST
        sync: false # سنقوم بإدخال الرابط يدوياً في Render
      - key: DB_PORT
        value: "4000" # منفذ TiDB الافتراضي هو 4000
      - key: DB_DATABASE
        value: test
      - key: DB_USERNAME
        sync: false # سنقوم بإدخاله يدوياً في Render
      - key: DB_PASSWORD
        sync: false # سنقوم بإدخاله يدوياً في Render
      - key: APP_KEY
        sync: false # مفتاح التطبيق الخاص بك
